# ── LLM API Keys ─────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_key_here        # optionnel

# ── Source DB (ERP Legacy) ────────────────────────────────────
SOURCE_DB_URL=postgresql://erp_user:erp_pass@localhost:5432/erp_legacy

# ── Target DB (Cloud / Supabase) ─────────────────────────────
TARGET_DB_URL=postgresql://dw_user:dw_pass@localhost:5433/cloud_dw

# ── Migration Config ──────────────────────────────────────────
MIGRATION_RUN_ID=run_2024_v1
BATCH_SIZE=100
QUALITY_SCORE_THRESHOLD=0.80              # bloquer si < 80% qualité

# ── Prefect ───────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api
